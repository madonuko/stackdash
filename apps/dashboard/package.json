{
	"name": "stack-dashboard",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"cf:dev": "bun run build && wrangler dev --local-protocol http",
		"cf:dev:remote": "bun run build && wrangler dev --remote",
		"cf:deploy": "wrangler deploy --env=\"\"",
		"cf:deploy:preview": "bun run build && wrangler deploy --env preview",
		"email:dev": "bse dev -c src/routes/layout.css",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config auth.config.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@better-svelte-email/cli": "^2.0.0",
		"@fontsource-variable/geist": "^5.2.8",
		"@fontsource-variable/inter": "^5.2.8",
		"@icons-pack/svelte-simple-icons": "^7.2.0",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.14.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.2",
		"@types/pg": "^8.20.0",
		"better-auth": "^1.6.0",
		"bits-ui": "^2.17.2",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"mode-watcher": "^1.1.0",
		"pg": "^8.20.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.5",
		"wrangler": "^4.80.0"
	},
	"dependencies": {
		"@better-auth/core": "^1.6.0",
		"@better-auth/passkey": "^1.6.0",
		"@better-auth/telemetry": "^1.6.0",
		"@better-auth/utils": "^0.4.0",
		"@better-svelte-email/components": "^2.0.0",
		"@better-svelte-email/server": "^2.0.0",
		"arktype": "^2.2.0",
		"autumn-js": "^1.2.18",
		"ip-address": "^10.2.0",
		"ky": "^2.0.0",
		"qrcode-svg": "^1.1.0",
		"ulid": "^3.0.2",
		"yaml": "^2.9.0"
	}
}
