# Database (direct connection for local dev without Wrangler)
DATABASE_URL="postgres://user:password@host:port/db-name"

# App
ORIGIN="http://localhost:5173"

# Better Auth
# For production use 32+ characters generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# OAuth — GitHub (https://github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Proxmox VE backend
PROXMOX_API_URL="https://pve.example.com:8006"
PROXMOX_TOKEN_ID="root@pam!stack"
PROXMOX_TOKEN_SECRET=""
