# DATABASE CONNECTION STRING
# yes, it has a dumb name, blame cloudflare
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE="postgres://user:password@host:port/db-name"

# The canonical URL.
ORIGIN="http://localhost:5173"

# Better Auth
# For production use 32+ characters generated with high entropy
# https://www.better-auth.com/docs/installation
# In development, it doesn't really matter.
BETTER_AUTH_SECRET=""

# Netbox
NETBOX_API_TOKEN="nbt_xxx.xxx"
NETBOX_API_URL="http://0.0.0.0:8000"

# Email
# If these variables aren't filled out, it will print it in console instead.
EMAIL_FROM_ADDRESS="no-reply@example.com"
EMAIL_FROM_NAME="Fyra Stack"
EMAIL_REPLY_TO="support@example.com"
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN="" # Cloudflare -> Top-right user icon -> Profile -> API Tokens -> Create Token. Scope to Email Sending.

# Autumn billing
AUTUMN_SECRET=""
AUTUMN_DEFAULT_PLAN_ID="stack" # This should not be changed.
AUTUMN_SERVER_ENTITY_FEATURE_ID="active_servers" # This should not be changed.
BILLING_METER_SECRET="" # random strings

# OAuth — GitHub (https://github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Proxmox VE backend
PROXMOX_API_URL="https://pve.example.com:8006"
PROXMOX_TOKEN_ID="root@pam!stack"
PROXMOX_TOKEN_SECRET=""
